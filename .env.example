COMPOSE_PROJECT_NAME=ledger

FRONTEND_HOST_PORT=3000
API_HOST_PORT=8080
POSTGRES_HOST_PORT=5433

POSTGRES_DB=ledger
POSTGRES_USER=ledger
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgres://ledger:change-this-postgres-password@postgres:5432/ledger?sslmode=disable

DEFAULT_ADMIN_NAME=Administrator
DEFAULT_ADMIN_EMAIL=admin@ledger.local
DEFAULT_ADMIN_PASSWORD=change-this-admin-password

DEFAULT_USER_ENABLED=true
DEFAULT_USER_NAME=User
DEFAULT_USER_EMAIL=user@ledger.local
DEFAULT_USER_PASSWORD=change-this-user-password
